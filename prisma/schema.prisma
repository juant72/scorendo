generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════
// USERS & AUTH
// ═══════════════════════════════════════

model User {
  walletAddress    String   @id
  displayName      String?
  email            String?  @unique
  avatarUrl        String?
  avatarSeed       String?

  totalPoints      Int      @default(0)
  currentStreak    Int      @default(0)
  bestStreak       Int      @default(0)
  totalCorrect     Int      @default(0)
  totalExact       Int      @default(0)
  totalPredictions Int      @default(0)
  accuracy         Float    @default(0)
  isAdmin          Boolean  @default(false)
  language         String   @default("en")

  predictions      Prediction[]
  contestEntries   UserContestEntry[]
  transactions     Transaction[]
  achievements     UserAchievement[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Session {
  id          String   @id @default(cuid())
  userWallet  String
  token       String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([token])
}

// ═══════════════════════════════════════
// TOURNAMENT STRUCTURE
// ═══════════════════════════════════════

model Competition {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  category    String?      // e.g., 'Domestic League', 'International Cup'
  country     String?
  logoUrl     String?
  tournaments Tournament[]
  createdAt   DateTime     @default(now())
}

model Tournament {
  id            String           @id @default(cuid())
  competitionId String?
  competition   Competition?     @relation(fields: [competitionId], references: [id])
  name          String
  slug          String           @unique
  startDate     DateTime
  endDate       DateTime
  status        TournamentStatus @default(UPCOMING)

  phases    Phase[]
  teams     TournamentTeam[]
  contests  Contest[]

  createdAt DateTime @default(now())
}

enum TournamentStatus {
  UPCOMING
  GROUP_STAGE
  KNOCKOUT
  FINISHED
}

model Phase {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  name         String
  slug         String
  order        Int
  startDate    DateTime
  endDate      DateTime
  multiplier   Float      @default(1.0)

  matches      Match[]
  groups       Group[]
  contests     Contest[]

  @@unique([tournamentId, slug])
}

model Group {
  id      String           @id @default(cuid())
  phaseId String
  phase   Phase            @relation(fields: [phaseId], references: [id])
  name    String

  teams   TournamentTeam[]

  @@unique([phaseId, name])
}

model Team {
  id            String           @id @default(cuid())
  name          String           @unique
  code          String           @unique
  flagUrl       String?
  confederation String

  homeMatches   Match[]          @relation("HomeTeam")
  awayMatches   Match[]          @relation("AwayTeam")
  tournaments   TournamentTeam[]
}

model TournamentTeam {
  id           String     @id @default(cuid())
  teamId       String
  team         Team       @relation(fields: [teamId], references: [id])
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  groupId      String?
  group        Group?     @relation(fields: [groupId], references: [id])
  seed         Int?

  @@unique([teamId, tournamentId])
}

model Venue {
  id       String    @id @default(cuid())
  name     String
  city     String
  country  String
  zone     VenueZone
  capacity Int?

  matches  Match[]
}

enum VenueZone {
  USA_EAST
  USA_CENTRAL
  USA_WEST
  MEXICO
  CANADA
}

// ═══════════════════════════════════════
// MATCHES
// ═══════════════════════════════════════

model Match {
  id          String      @id @default(cuid())
  phaseId     String
  phase       Phase       @relation(fields: [phaseId], references: [id])
  matchNumber Int
  homeTeamId  String
  homeTeam    Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId  String
  awayTeam    Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  venueId     String?
  venue       Venue?      @relation(fields: [venueId], references: [id])
  kickoff     DateTime
  status      MatchStatus @default(SCHEDULED)
  homeScore   Int?
  awayScore   Int?
  extraTime   Boolean     @default(false)
  penalties   Boolean     @default(false)

  predictions Prediction[]

  updatedAt   DateTime    @updatedAt

  @@index([phaseId])
  @@index([kickoff])
  @@index([status])
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

// ═══════════════════════════════════════
// PREDICTIONS
// ═══════════════════════════════════════

model Prediction {
  id              String            @id @default(cuid())
  userWallet      String
  user            User              @relation(fields: [userWallet], references: [walletAddress])
  matchId         String
  match           Match             @relation(fields: [matchId], references: [id])
  contestId       String
  contest         Contest           @relation(fields: [contestId], references: [id])

  predictedWinner PredictionOutcome
  predictedHome   Int?
  predictedAway   Int?

  pointsEarned    Int               @default(0)
  isCorrectWinner Boolean           @default(false)
  isExactScore    Boolean           @default(false)
  scored          Boolean           @default(false)

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([userWallet, matchId, contestId])
  @@index([matchId])
  @@index([userWallet])
  @@index([contestId])
}

enum PredictionOutcome {
  HOME
  AWAY
  DRAW
}

// ═══════════════════════════════════════
// CONTESTS (PRIZE POOLS)
// ═══════════════════════════════════════

model Contest {
  id               String        @id @default(cuid())
  name             String
  slug             String        @unique
  description      String?
  type             ContestType
  tier             ContestTier   @default(FREE)
  isPrivate        Boolean       @default(false)
  inviteCode       String?       @unique
  customLogoUrl    String?
  customBrandName  String?

  // Prize pool — non-custodial architecture
  // Phase 1: treasuryWallet (multisig via Squads)
  // Phase 2: vaultPDA (Anchor smart contract)
  entryFeeLamports BigInt        @default(0)
  entryFeeSOL      Float         @default(0)
  prizePool        BigInt        @default(0)
  treasuryWallet   String?
  vaultPDA         String?
  vaultBump        Int?
  distribution     Json
  orgCutPercent    Float         @default(15)

  // Scope
  tournamentId     String?
  tournament       Tournament?   @relation(fields: [tournamentId], references: [id])
  phaseId          String?
  phase            Phase?        @relation(fields: [phaseId], references: [id])
  zone             VenueZone?
  matchDay         DateTime?

  // Timing
  startDate        DateTime
  endDate          DateTime
  registrationEnd  DateTime
  status           ContestStatus @default(UPCOMING)

  // Participants
  minParticipants  Int           @default(2)
  maxParticipants  Int?
  currentEntries   Int           @default(0)

  entries          UserContestEntry[]
  predictions      Prediction[]
  transactions     Transaction[]

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([status])
  @@index([type])
  @@index([startDate])
}

enum ContestType {
  GRAND_TOURNAMENT
  PHASE
  GROUP_BATTLE
  ZONE
  MATCH_DAY
  WEEKLY
  BRACKET
}

enum ContestTier {
  FREE
  MICRO
  STANDARD
  PREMIUM
  VIP
}

enum ContestStatus {
  UPCOMING
  REGISTRATION
  ACTIVE
  SCORING
  DISTRIBUTING
  FINISHED
  CANCELLED
  REFUNDED
}

model UserContestEntry {
  id               String    @id @default(cuid())
  userWallet       String
  user             User      @relation(fields: [userWallet], references: [walletAddress])
  contestId        String
  contest          Contest   @relation(fields: [contestId], references: [id])

  entryTxSignature String?
  entryPaid        Boolean   @default(false)
  entryPaidAt      DateTime?
  isFreeEntry      Boolean   @default(false)

  finalRank        Int?
  finalPoints      Int       @default(0)
  prizeAmount      BigInt?
  prizeClaimed     Boolean   @default(false)
  claimTxSignature String?

  createdAt        DateTime  @default(now())

  @@unique([userWallet, contestId])
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  userWallet  String?
  user        User?           @relation(fields: [userWallet], references: [walletAddress])
  contestId   String?
  contest     Contest?        @relation(fields: [contestId], references: [id])
  amount      BigInt
  txSignature String          @unique
  status      TxStatus        @default(PENDING)

  createdAt   DateTime        @default(now())
}

enum TransactionType {
  ENTRY_FEE
  PRIZE_PAYOUT
  ORG_CUT
  REFUND
}

enum TxStatus {
  PENDING
  CONFIRMED
  FAILED
}

// ═══════════════════════════════════════
// GAMIFICATION
// ═══════════════════════════════════════

model Achievement {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String
  description String
  icon        String
  rarity      AchievementRarity
  condition   Json

  users       UserAchievement[]
}

enum AchievementRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

model UserAchievement {
  id            String      @id @default(cuid())
  userWallet    String
  user          User        @relation(fields: [userWallet], references: [walletAddress])
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  unlockedAt    DateTime    @default(now())

  @@unique([userWallet, achievementId])
}

// ═══════════════════════════════════════
// ADMIN AUDIT LOG
// ═══════════════════════════════════════

model AdminLog {
  id          String   @id @default(cuid())
  adminWallet String
  action      String
  entityType  String
  entityId    String
  data        Json
  createdAt   DateTime @default(now())

  @@index([adminWallet])
  @@index([entityType, entityId])
}
