generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  walletAddress    String             @id
  displayName      String?
  avatarSeed       String?
  totalPoints      Int                @default(0)
  currentStreak    Int                @default(0)
  bestStreak       Int                @default(0)
  totalCorrect     Int                @default(0)
  totalExact       Int                @default(0)
  totalPredictions Int                @default(0)
  accuracy         Float              @default(0)
  isAdmin          Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  avatarUrl        String?
  email            String?            @unique
  language         String             @default("en")
  xp               Int                @default(0)
  level            Int                @default(1)
  predictions      Prediction[]
  transactions     Transaction[]
  achievements     UserAchievement[]
  contestEntries   UserContestEntry[]
}

model Session {
  id         String   @id @default(cuid())
  userWallet String
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([token])
}

model Competition {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  category    String?
  country     String?
  logoUrl     String?
  createdAt   DateTime     @default(now())
  tournaments Tournament[]
}

model Tournament {
  id            String           @id @default(cuid())
  name          String
  slug          String           @unique
  startDate     DateTime
  endDate       DateTime
  status        TournamentStatus @default(UPCOMING)
  createdAt     DateTime         @default(now())
  competitionId String?
  contests      Contest[]
  phases        Phase[]
  competition   Competition?     @relation(fields: [competitionId], references: [id])
  teams         TournamentTeam[]
}

model Phase {
  id           String     @id @default(cuid())
  tournamentId String
  name         String
  slug         String
  order        Int
  startDate    DateTime
  endDate      DateTime
  multiplier   Float      @default(1.0)
  contests     Contest[]
  groups       Group[]
  matches      Match[]
  tournament   Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([tournamentId, slug])
}

model Group {
  id      String           @id @default(cuid())
  phaseId String
  name    String
  phase   Phase            @relation(fields: [phaseId], references: [id])
  teams   TournamentTeam[]

  @@unique([phaseId, name])
}

model Team {
  id            String           @id @default(cuid())
  name          String           @unique
  code          String           @unique
  flagUrl       String?
  confederation String
  awayMatches   Match[]          @relation("AwayTeam")
  homeMatches   Match[]          @relation("HomeTeam")
  tournaments   TournamentTeam[]
}

model TournamentTeam {
  id           String     @id @default(cuid())
  teamId       String
  tournamentId String
  groupId      String?
  seed         Int?
  group        Group?     @relation(fields: [groupId], references: [id])
  team         Team       @relation(fields: [teamId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id])

  @@unique([teamId, tournamentId])
}

model Venue {
  id       String    @id @default(cuid())
  name     String
  city     String
  country  String
  zone     VenueZone
  capacity Int?
  matches  Match[]
}

model Match {
  id          String       @id @default(cuid())
  phaseId     String
  matchNumber Int
  homeTeamId  String
  awayTeamId  String
  venueId     String?
  kickoff     DateTime
  status      MatchStatus  @default(SCHEDULED)
  homeScore   Int?
  awayScore   Int?
  extraTime   Boolean      @default(false)
  penalties   Boolean      @default(false)
  updatedAt   DateTime     @updatedAt
  awayTeam    Team         @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeTeam    Team         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  phase       Phase        @relation(fields: [phaseId], references: [id])
  venue       Venue?       @relation(fields: [venueId], references: [id])
  predictions Prediction[]

  @@index([phaseId])
  @@index([kickoff])
  @@index([status])
}

model Prediction {
  id              String            @id @default(cuid())
  userWallet      String
  matchId         String
  contestId       String
  predictedWinner PredictionOutcome
  predictedHome   Int?
  predictedAway   Int?
  pointsEarned    Int               @default(0)
  isCorrectWinner Boolean           @default(false)
  isExactScore    Boolean           @default(false)
  scored          Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  contest         Contest           @relation(fields: [contestId], references: [id])
  match           Match             @relation(fields: [matchId], references: [id])
  user            User              @relation(fields: [userWallet], references: [walletAddress])

  @@unique([userWallet, matchId, contestId])
  @@index([matchId])
  @@index([userWallet])
  @@index([contestId])
}

model Contest {
  id               String             @id @default(cuid())
  name             String
  slug             String             @unique
  description      String?
  type             ContestType
  tier             ContestTier        @default(FREE)
  entryFeeLamports BigInt             @default(0)
  entryFeeSOL      Float              @default(0)
  prizePool        BigInt             @default(0)
  treasuryWallet   String?
  vaultPDA         String?
  vaultBump        Int?
  distribution     Json
  orgCutPercent    Float              @default(15)
  tournamentId     String?
  phaseId          String?
  zone             VenueZone?
  matchDay         DateTime?
  startDate        DateTime
  endDate          DateTime
  registrationEnd  DateTime
  status           ContestStatus      @default(UPCOMING)
  minParticipants  Int                @default(2)
  maxParticipants  Int?
  currentEntries   Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  customBrandName  String?
  customLogoUrl    String?
  inviteCode       String?            @unique
  isPrivate        Boolean            @default(false)
  phase            Phase?             @relation(fields: [phaseId], references: [id])
  tournament       Tournament?        @relation(fields: [tournamentId], references: [id])
  predictions      Prediction[]
  transactions     Transaction[]
  entries          UserContestEntry[]

  @@index([status])
  @@index([type])
  @@index([startDate])
}

model UserContestEntry {
  id               String    @id @default(cuid())
  userWallet       String
  contestId        String
  entryTxSignature String?
  entryPaid        Boolean   @default(false)
  entryPaidAt      DateTime?
  isFreeEntry      Boolean   @default(false)
  finalRank        Int?
  finalPoints      Int       @default(0)
  prizeAmount      BigInt?
  prizeClaimed     Boolean   @default(false)
  claimTxSignature String?
  createdAt        DateTime  @default(now())
  contest          Contest   @relation(fields: [contestId], references: [id])
  user             User      @relation(fields: [userWallet], references: [walletAddress])

  @@unique([userWallet, contestId])
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  userWallet  String?
  contestId   String?
  amount      BigInt
  txSignature String          @unique
  status      TxStatus        @default(PENDING)
  createdAt   DateTime        @default(now())
  contest     Contest?        @relation(fields: [contestId], references: [id])
  user        User?           @relation(fields: [userWallet], references: [walletAddress])
}

model Achievement {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String
  description String
  icon        String
  rarity      AchievementRarity
  condition   Json
  users       UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userWallet    String
  achievementId String
  unlockedAt    DateTime    @default(now())
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  user          User        @relation(fields: [userWallet], references: [walletAddress])

  @@unique([userWallet, achievementId])
}

model AdminLog {
  id          String   @id @default(cuid())
  adminWallet String
  action      String
  entityType  String
  entityId    String
  data        Json
  createdAt   DateTime @default(now())

  @@index([adminWallet])
  @@index([entityType, entityId])
}

enum TournamentStatus {
  UPCOMING
  GROUP_STAGE
  KNOCKOUT
  FINISHED
}

enum VenueZone {
  USA_EAST
  USA_CENTRAL
  USA_WEST
  MEXICO
  CANADA
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum PredictionOutcome {
  HOME
  AWAY
  DRAW
}

enum ContestType {
  GRAND_TOURNAMENT
  PHASE
  GROUP_BATTLE
  ZONE
  MATCH_DAY
  WEEKLY
  BRACKET
}

enum ContestTier {
  FREE
  MICRO
  STANDARD
  PREMIUM
  VIP
}

enum ContestStatus {
  UPCOMING
  REGISTRATION
  ACTIVE
  SCORING
  DISTRIBUTING
  FINISHED
  CANCELLED
  REFUNDED
}

enum TransactionType {
  ENTRY_FEE
  PRIZE_PAYOUT
  ORG_CUT
  REFUND
}

enum TxStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum AchievementRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}
